# Same Supabase project as the main dogedin site — anon key only. The page
# reads a single anonymized aggregate function (media_kit_stats), so it is
# safe to host publicly and share with prospective advertisers.
# Leave blank to render built-in sample data (labelled as such).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Absolute URL of the main site, for the inquiry CTA links.
NEXT_PUBLIC_SITE_URL=

# Where "email us" links point.
NEXT_PUBLIC_CONTACT_EMAIL=dogedin.com@gmail.com
